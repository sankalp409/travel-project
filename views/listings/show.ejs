  <% layout("/layouts/boilerplate") -%>
  <div class="row mt-3 show-card col-6 offset-1" style="width:70rem;">


    <h3>Listing Details</h3>


    <img class="card-show-img" src="<%= listing.image.url %>" alt="place image">
    <div class="card-body">
      <p class="show-card-text">
        <b> <%=listing.title%> </b> <br>
        <%=listing.description%> <br>
        &#8377 <%=listing.price.toLocaleString("en-IN")%> <br>
        <%=listing.location%> <br>
        <%=listing.country%> <br>
      </p>
    </div>

    <div class="col-2">
      <a href="/listings/<%=listing._id%>/edit" class="btn btn-primary">Edit This Listing</a> <br><br>
      <form method="post" action="/listings/<%=listing._id%>?_method=DELETE"><button class="btn btn-danger">Delete This listing</button></form>
    </div>





    <br><br>

  </div>